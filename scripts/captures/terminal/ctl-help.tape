Output docs/public/assets/images/terminal/ctl-help.gif

Set Shell "bash"
Set FontSize 18
Set Width 1320
Set Height 760
Set Padding 24
Set Margin 12
Set MarginFill "#f5efe4"
Set BorderRadius 12
Set WindowBar Colorful
Set TypingSpeed 16ms

Type "./target/debug/trust-runtime ctl --help | sed -n '1,40p'"
Enter
Sleep 2200ms
