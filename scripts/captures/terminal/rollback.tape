Output docs/public/assets/images/terminal/rollback.gif

Set Shell "bash"
Set FontSize 18
Set Width 1180
Set Height 620
Set Padding 24
Set Margin 12
Set MarginFill "#f5efe4"
Set BorderRadius 12
Set WindowBar Colorful
Set TypingSpeed 16ms

Type "./target/debug/trust-runtime rollback --help"
Enter
Sleep 1800ms
