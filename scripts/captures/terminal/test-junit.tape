Output docs/public/assets/images/terminal/test-junit.gif

Set Shell "bash"
Set FontSize 18
Set Width 1320
Set Height 760
Set Padding 24
Set Margin 12
Set MarginFill "#f5efe4"
Set BorderRadius 12
Set WindowBar Colorful
Set TypingSpeed 16ms

Type "./scripts/captures/terminal/helpers/test-junit-demo.sh"
Enter
Sleep 2600ms
